{
    // Live Sass Compiler sozlamalari
    "liveSassCompile.settings.formats": [
        {
            "format": "expanded",        // CSS o'qishga oson holatda chiqadi
            "extensionName": ".css",
            "savePath": "/css"           // Kompilyatsiya bo'lgan faylni /css papkasiga tashlaydi
        },
        {
            "format": "compressed",      // Proyekt tayyor bo'lganda siqilgan (minified) holat
            "extensionName": ".min.css",
            "savePath": "/css"
        }
    ],

    // SCSS fayllari ichida tavsiyalar va avtomatik tugatish
    "scss.validate": true,
    "editor.suggestSelection": "first",
    
    // Fayllarni saqlaganda avtomatik formatlash (tartibga solish)
    "editor.formatOnSave": true,
    "[scss]": {
        "editor.defaultFormatter": "vscode.css-language-features"
    },

    // Emmet-ni SCSS ichida ham ishlashi uchun
    "emmet.includeLanguages": {
        "scss": "css"
    },

    // Arxitekturadagi _ (pastki chiziq) bilan boshlangan fayllarni alohida CSS qilmaslik
    "liveSassCompile.settings.excludeList": [
        "**/node_modules/**",
        ".vscode/**"
    ],
    
    // Autoprefixer: Brauzerlar uchun avtomatik prefikslar qo'shish (-webkit-, -moz-)
    "liveSassCompile.settings.autoprefix": [
        "> 1%",
        "last 2 versions"
    ]
}